(define (problem blocksworld-problem)
    (:domain blocksworld)
    (:objects
        orange red yellow blue purple green robot1 - robot
    )
    (:init
        (ontable orange)
        (ontable red)
        (ontable yellow)
        (ontable blue)
        (ontable purple)
        (ontable green)
        (clear orange)
        (clear red)
        (clear yellow)
        (clear blue)
        (clear purple)
        (clear green)
        (handempty robot1)
    )
    (:goal (and
        (on orange red)
        (on red yellow)
        (on blue purple)
        (on purple green)
    ))
)