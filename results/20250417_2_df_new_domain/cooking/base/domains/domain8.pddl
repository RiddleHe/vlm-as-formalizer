(define (domain cooking)
    (:requirements :strips)
    (:predicates
        (sliced ?item)
        (in-bowl ?item)
        (on-table ?item)
        (holding ?item)
        (clear ?item)
    )
    (:action slice
        :parameters (?item)
        :precondition (and (on-table ?item) (clear ?item))
        :effect (and (sliced ?item) (not (clear ?item)))
    )
    (:action place-in-bowl
        :parameters (?item)
        :precondition (and (sliced ?item) (holding ?item))
        :effect (and (in-bowl ?item) (not (holding ?item)))
    )
)