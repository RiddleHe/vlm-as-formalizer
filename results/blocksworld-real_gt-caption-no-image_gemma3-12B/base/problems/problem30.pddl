(define (problem blocksworld-problem)
    (:domain blocksworld)
    (:objects
        orange red yellow purple green blue - block
        robot1 - robot
    )
    (:init
        (ontable orange)
        (ontable red)
        (ontable yellow)
        (ontable purple)
        (ontable green)
        (ontable blue)
        (clear orange)
        (clear red)
        (clear yellow)
        (clear purple)
        (clear green)
        (clear blue)
        (handempty robot1)
        (on orange red)
        (on red yellow)
        (on yellow purple)
        (on purple green)
        (on green blue)
    )
    (:goal (and
        (on orange purple)
        (on purple green)
        (on green blue)
        (on blue yellow)
        (on yellow red)
    ))
)