  (:domain blocksworld)
  (:objects
    red_block_top_of_tower - block
    yellow_block_second_in_tower - block
    purple_block_middle_in_tower - block
    blue_block_second_from_bottom_in_tower - block
    green_block_bottom_of_tower - block
