    (clear blue-block)
    (clear purple-block)
    (clear red-block)
    (clear yellow-block)

    ;; robot state
    (handempty robot-arm)
  )
  (:goal
    (and
      (on orange-block yellow-block)
      (on green-block blue-block)
      (on red-block purple-block)
    )
  )
)
